    {
      "name": "📚 Livros",
      "item": [
        {
          "name": "CT-A01 – POST /api/livros (sucesso)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status deve ser 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Resposta contém isbn', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.isbn).to.eql('978-85-333-0099-9');",
                  "});",
                  "pm.test('Livro está disponível', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.disponivel).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isbn\": \"978-85-333-0099-9\",\n  \"titulo\": \"Livro de Teste\",\n  \"autor\": \"Autor Teste\",\n  \"anoPub\": 2020\n}"
            },
            "url": { "raw": "{{base_url}}/api/livros", "host": ["{{base_url}}"], "path": ["api", "livros"] }
          }
        },
        {
          "name": "CT-A02 – POST /api/livros (ISBN duplicado → 409)",
