    {
      "name": "EMPRESTIMOS",
      "item": [
        {
          "name": "CT-A07 - POST /api/emprestimos sucesso (201)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Garante livro disponivel antes do emprestimo",
                  "pm.sendRequest({url:pm.variables.get('base_url')+'/api/livros', method:'POST',",
                  "  header:{'Content-Type':'application/json'},",
                  "  body:{mode:'raw',raw:JSON.stringify({isbn:'978-85-333-0001-1',titulo:'Dom Casmurro',autor:'Machado de Assis',anoPub:1899})}",
                  "}, ()=>{});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('ID no formato EMP-XXXX', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.id).to.match(/^EMP-\\d{4}$/);",
                  "  pm.collectionVariables.set('emprestimo_id', j.id);",
                  "});",
                  "pm.test('Livro indisponivel', () => pm.expect(pm.response.json().livro.disponivel).to.be.false);",
                  "pm.test('Prazo presente', () => pm.expect(pm.response.json()).to.have.property('prazo'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"isbn\":\"978-85-333-0001-1\",\"usuario\":\"Ana Silva\",\"data\":\"2025-06-01\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/emprestimos",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "emprestimos"
