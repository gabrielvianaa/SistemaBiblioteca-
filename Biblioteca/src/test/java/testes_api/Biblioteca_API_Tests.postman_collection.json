    {
      "name": "📋 Empréstimos",
      "item": [
        {
          "name": "CT-A07 – POST /api/emprestimos (sucesso)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Garante que o livro existe antes de emprestar",
                  "pm.sendRequest({",
                  "  url: pm.variables.get('base_url') + '/api/livros',",
                  "  method: 'POST',",
                  "  header: {'Content-Type': 'application/json'},",
                  "  body: { mode: 'raw', raw: JSON.stringify({isbn:'978-85-333-0001-1',titulo:'Dom Casmurro',autor:'Machado de Assis',anoPub:1899}) }",
                  "}, function(err, res) {});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status deve ser 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Resposta contém ID de empréstimo', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.id).to.match(/^EMP-\\d{4}$/);",
                  "    pm.collectionVariables.set('emprestimo_id', json.id);",
                  "});",
                  "pm.test('Livro marcado como indisponível', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.livro.disponivel).to.be.false;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isbn\": \"978-85-333-0001-1\",\n  \"usuario\": \"Ana\",\n  \"data\": \"2025-06-01\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/emprestimos", "host": ["{{base_url}}"], "path": ["api", "emprestimos"] }
          }
        },
