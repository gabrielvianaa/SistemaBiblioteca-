      "name": "AUTH",
      "item": [
        {
          "name": "CT-A00 - Login valido (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retorna perfil ADMIN', () => pm.expect(pm.response.json().perfil).to.equal('ADMIN'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"login\":\"admin\",\"senha\":\"admin123\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "CT-A00b - Login invalido (401)",
          "event": [
